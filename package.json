{
  "name": "sanity-next-cloudflare-starter",
  "description": "Sanity + Next.js + Cloudflare Starter Template: A scalable starter template combining Sanity CMS, Next.js, and Cloudflare for building high-performance, content-first web applications.",
  "keywords": [
    "Sanity",
    "Next.js",
    "OpenNext",
    "Cloudflare",
    "Headless CMS",
    "Visual Editing",
    "Live Content API (LCAPI)",
    "Real-time"
  ],
  "homepage": "https://github.com/sanity-io/sanity-template-nextjs-clean#readme",
  "bugs": {
    "url": "https://github.com/sanity-io/sanity-template-nextjs-clean/issues"
  },
  "workspaces": [
    "studio",
    "frontend"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel --print-label dev:*",
    "dev:next": "pnpm --filter frontend dev",
    "dev:studio": "pnpm --filter studio dev",
    "deploy": "npm-run-all --parallel --print-label deploy:*",
    "format": "prettier --cache --write .",
    "import-sample-data": "cd studio && sanity dataset import sample-data.tar.gz --replace",
    "lint": "pnpm --filter frontend lint",
    "type-check": "pnpm --recursive type-check",
    "validate": "sanity-template-validate"
  },
  "prettier": "@sanity/prettier-config",
  "devDependencies": {
    "@sanity/prettier-config": "^2.0.2",
    "@sanity/template-validator": "^3.0.0",
    "npm-run-all2": "^5.0.2",
    "prettier": "^3.7.3"
  }
}

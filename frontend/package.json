{
  "name": "frontend",
  "private": true,
  "scripts": {
    "prebuild": "pnpm run typegen",
    "build": "next build",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "predev": "pnpm run typegen",
    "dev": "next dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "typegen": "pnpm --filter studio run extract-types && sanity typegen generate"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.17.0",
    "@portabletext/react": "^6.0.2",
    "@sanity/client": "^7.13.2",
    "@sanity/image-url": "^1.2.0",
    "@sanity/preview-url-secret": "^4.0.2",
    "@sanity/uuid": "^3.0.2",
    "@tailwindcss/postcss": "^4.1.17",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.22",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.575.0",
    "next": "^16.1.6",
    "next-sanity": "^11.0.0",
    "postcss": "^8.5.6",
    "react": "^19.2.4",
    "react-dom": "19.2.4",
    "sanity": "^5.1.0",
    "sanity-image": "^1.0.0",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.1.17"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@types/node": "^20.19.25",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "^15.0.0",
    "typescript": "5.9.3",
    "wrangler": "^4.58.0"
  }
}
